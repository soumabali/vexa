# vexa — Production Environment
# Copy this file to .env and fill in real values before deployment.

# ─── Domains ───────────────────────────────────────────────────────────────────
WEB_DOMAIN=vexa.nexigo.my.id
API_DOMAIN=api-vexa.nexigo.my.id
TRAEFIK_DASHBOARD_DOMAIN=traefik.nexigo.my.id

# ─── Let's Encrypt ─────────────────────────────────────────────────────────────
ACME_EMAIL=sudhar.denpasar@gmail.com

# ─── Database ──────────────────────────────────────────────────────────────────
DB_USER=vexa
DB_PASSWORD=change-me-to-strong-password
DB_NAME=vexa

# ─── Secrets ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-32-byte-secret
JWT_REFRESH_SECRET=change-me-to-32-byte-secret
# Generate with: openssl rand -hex 32 (used for credential encryption)
ENCRYPTION_KEY=change-me-to-32-byte-key

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Must include the web domain (and any extra origins you want to allow)
ALLOWED_ORIGINS=https://vexa.nexigo.my.id

# ─── WireGuard ─────────────────────────────────────────────────────────────────
WG_ENABLED=true
WG_SUBNET=10.200.200.0/24
WG_PORT_RANGE=51820-51830
WG_ROTATION_DAYS=90
WG_MAX_TUNNELS_PER_USER=10
WG_MAX_TOTAL_TUNNELS=1000
# Set to false once WireGuard is installed on the host
WG_MOCK_FALLBACK=false

# ─── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info
SERVER_PORT=8080

# Internal URLs (used when not running behind Traefik)
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}?sslmode=disable
REDIS_ADDR=localhost:6379

# Frontend build-time URLs (used by docker-compose.prod.yml)
NEXT_PUBLIC_API_URL=https://${API_DOMAIN}
NEXT_PUBLIC_WS_URL=wss://${API_DOMAIN}
